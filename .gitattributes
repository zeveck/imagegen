# Normalize line endings on checkin; check out with native LF.
* text=auto eol=lf

# Explicitly LF for scripts and text formats
*.js    text eol=lf
*.cjs   text eol=lf
*.mjs   text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.sh    text eol=lf
*.toml  text eol=lf

# Binary files
*.png   binary
*.jpg   binary
*.jpeg  binary
*.webp  binary
*.gif   binary
*.ico   binary
*.pdf   binary
